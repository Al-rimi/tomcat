{
	"compilerOptions": {
		"module": "ES2020",
		"target": "ES2020",
		"lib": [
			"ES2020",
			"DOM"
		],
		"outDir": "dist",
		"sourceMap": true,
		"inlineSources": true,
		"rootDir": ".",
		"strict": true,
		"noUnusedLocals": true,
		"noImplicitAny": true,
		"moduleResolution": "node",
		"ignoreDeprecations": "5.0",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"noUnusedParameters": true,
		"types": [
			"node",
			"vscode",
			"mocha",
			"chai"
		]
	},
	"include": [
		"src/**/*.ts",
		"*.ts"
	],
	"exclude": [
		"node_modules",
		"test",
		"**/*.test.ts"
	]
}