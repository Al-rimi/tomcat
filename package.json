{
  "name": "tomcat",
  "displayName": "%ext.displayName%",
  "description": "%ext.description%",
  "version": "4.2.1",
  "publisher": "Al-rimi",
  "author": {
    "email": "alrimi@zjnu.edu.cn",
    "name": "Al raimi Abdullah",
    "url": "https://owared.com"
  },
  "icon": "resources/images/tomcat-logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Al-rimi/tomcat"
  },
  "bugs": {
    "url": "https://github.com/Al-rimi/tomcat/issues"
  },
  "homepage": "https://github.com/Al-rimi/tomcat",
  "keywords": [
    "apache tomcat",
    "tomcat",
    "server",
    "deployment",
    "javaEE",
    "java",
    "jsp",
    "vscode"
  ],
  "galleryBanner": {
    "color": "#4A90E2",
    "theme": "dark"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Debuggers"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/*"
  ],
  "engines": {
    "vscode": "^1.56.0",
    "node": ">=14.16.0"
  },
  "files": [
    "out/**/*",
    "resources/**/*",
    "package.json",
    "package.nls.json",
    "package.nls.zh-cn.json",
    "README.md",
    "README.zh-cn.md",
    "CHANGELOG.md",
    "LICENSE**"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "localizations": [
      {
        "languageId": "zh-cn",
        "translations": [
          {
            "id": "vscode",
            "path": "./package.nls.zh-cn.json"
          }
        ]
      }
    ],
    "languages": [
      {
        "id": "tomcat-log",
        "aliases": [
          "Tomcat Log"
        ],
        "extensions": [
          ".log"
        ],
        "configuration": "./resources/syntaxes/language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tomcat-log",
        "scopeName": "source.tomcat-log",
        "path": "./resources/syntaxes/tomcat-log.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "tomcat.deploy",
        "title": "%command.deploy.title%",
        "category": "%command.category%",
        "icon": {
          "light": "resources/images/tomcat-icon-light.svg",
          "dark": "resources/images/tomcat-icon-dark.svg"
        }
      },
      {
        "command": "tomcat.start",
        "title": "%command.start.title%"
      },
      {
        "command": "tomcat.stop",
        "title": "%command.stop.title%"
      },
      {
        "command": "tomcat.clean",
        "title": "%command.clean.title%"
      },
      {
        "command": "tomcat.manageInstances",
        "title": "%command.manageInstances.title%"
      },
      {
        "command": "tomcat.instances.refresh",
        "title": "%command.instances.refresh.title%",
        "icon": "$(sync)"
      },
      {
        "command": "tomcat.instances.kill",
        "title": "%command.instances.kill.title%",
        "icon": "$(trash)"
      },
      {
        "command": "tomcat.instances.openInBrowser",
        "title": "%command.instances.openInBrowser.title%"
      },
      {
        "command": "tomcat.apps.deploy",
        "title": "%command.apps.deploy.title%",
        "icon": "$(play)"
      },
      {
        "command": "tomcat.apps.openInBrowser",
        "title": "%command.apps.openInBrowser.title%"
      },
      {
        "command": "tomcat.apps.create",
        "title": "%command.apps.create.title%",
        "icon": "$(add)"
      },
      {
        "command": "tomcat.apps.undeploy",
        "title": "%command.apps.undeploy.title%",
        "icon": "$(debug-stop)"
      },
      {
        "command": "tomcat.instances.startNew",
        "title": "%command.instances.startNew.title%",
        "icon": "$(add)"
      },
      {
        "command": "tomcat.instances.configureField",
        "title": "%command.instances.configureField.title%",
        "icon": "$(gear)"
      },
      {
        "command": "tomcat.instances.addHome",
        "title": "%command.instances.addHome.title%",
        "icon": "$(add)"
      },
      {
        "command": "tomcat.instances.removeHome",
        "title": "%command.instances.removeHome.title%",
        "icon": "$(trash)"
      },
      {
        "command": "tomcat.instances.refreshVersions",
        "title": "%command.instances.refreshVersions.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "tomcat.instances.setActiveHome",
        "title": "%command.instances.setActiveHome.title%",
        "icon": "$(check)"
      },
      {
        "command": "tomcat.instances.addJavaHome",
        "title": "%command.instances.addJavaHome.title%",
        "icon": "$(add)"
      },
      {
        "command": "tomcat.instances.removeJavaHome",
        "title": "%command.instances.removeJavaHome.title%",
        "icon": "$(trash)"
      },
      {
        "command": "tomcat.instances.setActiveJavaHome",
        "title": "%command.instances.setActiveJavaHome.title%",
        "icon": "$(check)"
      },
      {
        "command": "tomcat.instances.setPort",
        "title": "%command.instances.setPort.title%"
      },
      {
        "command": "tomcat.ai.addListValue",
        "title": "%command.ai.addListValue.title%",
        "icon": "$(add)"
      },
      {
        "command": "tomcat.ai.removeListValue",
        "title": "%command.ai.removeListValue.title%",
        "icon": "$(trash)"
      },
      {
        "command": "tomcat.instances.addPort",
        "title": "%command.instances.addPort.title%",
        "icon": "$(add)"
      },
      {
        "command": "tomcat.instances.removePort",
        "title": "%command.instances.removePort.title%",
        "icon": "$(trash)"
      },
      {
        "command": "tomcat.instances.setBuildType",
        "title": "%command.instances.setBuildType.title%"
      },
      {
        "command": "tomcat.instances.setLogLevel",
        "title": "%command.instances.setLogLevel.title%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tomcat",
          "title": "%view.container.title%",
          "icon": "resources/images/tomcat-icon-dark.svg"
        }
      ]
    },
    "views": {
      "tomcat": [
        {
          "id": "tomcat.instancesView",
          "name": "%view.container.title%",
          "icon": "resources/images/tomcat-icon-dark.svg"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "tomcat.deploy",
          "when": "tomcat.showdeployButton",
          "group": "navigation",
          "tooltip": "%menu.deploy.tooltip%"
        }
      ],
      "view/title": [
        {
          "command": "tomcat.instances.refresh",
          "when": "view == tomcat.instancesView",
          "group": "navigation",
          "icon": "$(sync)"
        }
      ],
      "view/item/context": [
        {
          "command": "tomcat.instances.kill",
          "when": "view == tomcat.instancesView && viewItem == tomcatInstance",
          "group": "inline",
          "icon": "$(trash)"
        },
        {
          "command": "tomcat.apps.create",
          "when": "view == tomcat.instancesView && viewItem == tomcatAppsGroup",
          "group": "inline",
          "icon": "$(add)"
        },
        {
          "command": "tomcat.instances.startNew",
          "when": "view == tomcat.instancesView && viewItem == tomcatInstancesGroup",
          "group": "inline",
          "icon": "$(add)"
        },
        {
          "command": "tomcat.instances.removeHome",
          "when": "view == tomcat.instancesView && viewItem == tomcatHomeEntry",
          "group": "inline",
          "icon": "$(trash)"
        },
        {
          "command": "tomcat.instances.addHome",
          "when": "view == tomcat.instancesView && viewItem == tomcatHomeGroup",
          "group": "inline",
          "icon": "$(add)"
        },
        {
          "command": "tomcat.instances.setActiveHome",
          "when": "view == tomcat.instancesView && viewItem == tomcatHomeEntry",
          "group": "inline",
          "icon": "$(check)"
        },
        {
          "command": "tomcat.instances.removeJavaHome",
          "when": "view == tomcat.instancesView && viewItem == tomcatJavaHomeEntry",
          "group": "inline",
          "icon": "$(trash)"
        },
        {
          "command": "tomcat.instances.addJavaHome",
          "when": "view == tomcat.instancesView && viewItem == tomcatJavaHomeGroup",
          "group": "inline",
          "icon": "$(add)"
        },
        {
          "command": "tomcat.instances.setActiveJavaHome",
          "when": "view == tomcat.instancesView && viewItem == tomcatJavaHomeEntry",
          "group": "inline",
          "icon": "$(check)"
        },
        {
          "command": "tomcat.instances.addPort",
          "when": "view == tomcat.instancesView && viewItem == tomcatPortGroup",
          "group": "inline",
          "icon": "$(add)"
        },
        {
          "command": "tomcat.ai.addListValue",
          "when": "view == tomcat.instancesView && (viewItem == tomcatAIListGroup || viewItem == tomcatBaseGroup)",
          "group": "inline",
          "icon": "$(add)"
        },
        {
          "command": "tomcat.ai.removeListValue",
          "when": "view == tomcat.instancesView && viewItem == tomcatAIListValue",
          "group": "inline",
          "icon": "$(trash)"
        },
        {
          "command": "tomcat.instances.removePort",
          "when": "view == tomcat.instancesView && viewItem == tomcatPortEntry",
          "group": "inline",
          "icon": "$(trash)"
        },
        {
          "command": "tomcat.apps.deploy",
          "when": "view == tomcat.instancesView && viewItem == tomcatApp.stopped",
          "group": "inline",
          "icon": "$(play)"
        },
        {
          "command": "tomcat.apps.undeploy",
          "when": "view == tomcat.instancesView && viewItem == tomcatApp.running",
          "group": "inline",
          "icon": "$(debug-stop)"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "tomcat.language": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "zh-CN"
          ],
          "default": "auto",
          "enumDescriptions": [
            "%config.language.enum.auto%",
            "%config.language.enum.en%",
            "%config.language.enum.zh%"
          ],
          "description": "%config.language.description%"
        },
        "tomcat.ai": {
          "type": "object",
          "default": {},
          "description": "%config.ai.description%"
        },
        "tomcat.ai.provider": {
          "type": "string",
          "enum": [
            "none",
            "local",
            "aliyun-dashscope",
            "baichuan",
            "zhipu",
            "deepseek",
            "custom"
          ],
          "default": "none",
          "description": "%config.ai.provider.description%"
        },
        "tomcat.ai.endpoint": {
          "type": "string",
          "default": "http://127.0.0.1:11434/api/chat",
          "description": "%config.ai.endpoint.description%"
        },
        "tomcat.ai.endpoints": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "http://127.0.0.1:11434/api/chat"
          ],
          "description": "%config.ai.endpoints.description%"
        },
        "tomcat.ai.model": {
          "type": "string",
          "default": "qwen2.5:7b",
          "description": "%config.ai.model.description%"
        },
        "tomcat.ai.models": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "qwen2.5:7b"
          ],
          "description": "%config.ai.models.description%"
        },
        "tomcat.ai.apiKey": {
          "type": "string",
          "default": "",
          "description": "%config.ai.apiKey.description%"
        },
        "tomcat.ai.apiKeys": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%config.ai.apiKeys.description%"
        },
        "tomcat.ai.localStartCommand": {
          "type": "string",
          "default": "ollama serve",
          "description": "%config.ai.localStartCommand.description%"
        },
        "tomcat.ai.localStartCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "ollama serve"
          ],
          "description": "%config.ai.localStartCommands.description%"
        },
        "tomcat.ai.maxTokens": {
          "type": "number",
          "default": 128,
          "minimum": 1,
          "description": "%config.ai.maxTokens.description%"
        },
        "tomcat.ai.timeoutMs": {
          "type": "number",
          "default": 45000,
          "minimum": 1000,
          "description": "%config.ai.timeoutMs.description%"
        },
        "tomcat.ai.autoStartLocal": {
          "type": "boolean",
          "default": true,
          "description": "%config.ai.autoStartLocal.description%"
        },
        "tomcat.logEncoding": {
          "type": "string",
          "default": "utf8",
          "enum": [
            "utf8",
            "ascii",
            "utf-8",
            "utf16le",
            "utf-16le",
            "ucs2",
            "ucs-2",
            "base64",
            "base64url",
            "latin1",
            "binary",
            "hex"
          ],
          "description": "%config.logEncoding.description%"
        },
        "tomcat.logLevel": {
          "type": "string",
          "enum": [
            "DEBUG",
            "INFO",
            "SUCCESS",
            "HTTP",
            "APP",
            "WARN",
            "ERROR"
          ],
          "default": "INFO",
          "description": "%config.logLevel.description%"
        },
        "tomcat.showTimestamp": {
          "type": "boolean",
          "default": true,
          "description": "%config.showTimestamp.description%"
        },
        "tomcat.protectedWebApps": {
          "type": "array",
          "default": [
            "ROOT",
            "docs",
            "examples",
            "manager",
            "host-manager"
          ],
          "description": "%config.protectedWebApps.description%"
        },
        "tomcat.autoDeployMode": {
          "type": "string",
          "enum": [
            "Disable",
            "On Save",
            "On Shortcut"
          ],
          "default": "Disable",
          "scope": "machine",
          "description": "%config.autoDeployMode.description%"
        },
        "tomcat.buildType": {
          "type": "string",
          "enum": [
            "Local",
            "Maven",
            "Gradle"
          ],
          "default": "Local",
          "description": "%config.buildType.description%"
        },
        "tomcat.browser": {
          "type": "string",
          "enum": [
            "Disable",
            "Google Chrome",
            "Microsoft Edge",
            "Firefox",
            "Safari",
            "Brave",
            "Opera"
          ],
          "default": "Google Chrome",
          "description": "%config.browser.description%"
        },
        "tomcat.port": {
          "scope": "machine",
          "type": "number",
          "default": 8080,
          "minimum": 1024,
          "maximum": 49151,
          "errorMessage": "%config.port.error%",
          "description": "%config.port.description%"
        },
        "tomcat.ports": {
          "type": "array",
          "items": {
            "type": "number",
            "minimum": 1024,
            "maximum": 49151
          },
          "default": [],
          "description": "%config.ports.description%"
        },
        "tomcat.autoReloadBrowser": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoReloadBrowser.description%"
        },
        "tomcat.base": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "%config.base.description%"
        },
        "tomcat.bases": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "scope": "machine",
          "description": "%config.bases.description%"
        },
        "tomcat.homes": {
          "type": "array",
          "default": [],
          "scope": "machine",
          "description": "%config.homes.description%"
        },
        "tomcat.home": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "%config.home.description%"
        },
        "tomcat.javaHome": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "%config.javaHome.description%"
        },
        "tomcat.javaHomes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "scope": "machine",
          "description": "%config.javaHomes.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm install && npm run compile",
    "package": "npm run compile",
    "compile": "webpack --mode production",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext .ts",
    "test": "node ./node_modules/@vscode/test-electron/out/runTest --extensionDevelopmentPath=. --extensionTestsPath=out/test/suite",
    "check-localization": "node i18n_check.js",
    "coverage": "nyc --reporter=lcov npm test"
  },
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@types/chai": "^5.2.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.28",
    "@types/sinon": "^17.0.4",
    "@types/vscode": "^1.56.0",
    "@types/webpack-env": "^1.18.8",
    "@types/ws": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^2.15.0",
    "vscode-nls": "^5.2.0",
    "chai": "^4.5.0",
    "eslint": "^10.1.0",
    "mocha": "^11.7.5",
    "npm-force-resolutions": "^0.0.10",
    "sinon": "^17.0.1",
    "ts-loader": "^9.5.2",
    "typescript": "^5.7.3",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  },
  "overrides": {
    "mocha": {
      "diff": "8.0.3",
      "serialize-javascript": "7.0.4"
    },
    "serialize-javascript": "7.0.4",
    "brace-expansion": "^5.0.5",
    "minimist": "^1.2.7"
  },
  "dependencies": {
    "glob": "^11.0.1",
    "ws": "^7.4.6"
  }
}